  "version": "1.2.3",
  "author": "pix",
  "contributors": [
    "pix",
    "mikepa1",
    "homecineplexx",
    "iobroker-community-adapters <iobroker-community-adapters@gmx.de>"
  ],
  "homepage": "https://github.com/iobroker-community-adapters/ioBroker.homepilot",
  "repository": {
    "type": "git",
    "url": "https://github.com/iobroker-community-adapters/ioBroker.homepilot"
  },
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "homepilot",
    "blinds",
    "hardware",
    "jalousien",
    "rollo",
    "rollladen",
    "home automation"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "request": "^2.72.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.0",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node14": "^14.1.8",
    "@types/node": "^20.19.39",
    "typescript": "~5.9.2"
  },
  "bugs": {
    "url": "https://github.com/iobroker-community-adapters/ioBroker.homepilot/issues"
  },
  "main": "main.js",
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "maintainers": [
    "pix"
  ]
